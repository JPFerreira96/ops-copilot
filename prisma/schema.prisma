generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ticket {
  id          String   @id @default(cuid())
  title       String   
  description String   
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  tags        String   // stored as JSON string to support array in SQLite

  // Campos de cache da IA (obrigatórios no schema)
  aiSummary    String?
  aiNextSteps  String?   // stored as JSON string
  aiRiskLevel  String?
  aiCategories String?   // stored as JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hash da senha
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
